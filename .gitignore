# Browser capture artifacts. capture.mjs writes bare-named outputs into captures/.
captures/**
# Defensive: never track stray screenshots if one is written next to the harness.
app/tools/*.png
app/tools/*.png.console.txt
app/tools/*.frames/
app/target/**
app/web/node_modules/**
app/tools/node_modules/**
# Dev wasm-pack output. local_dev.sh serves /pkg/* from here; production uses app/web/pkg.
app/web/pkg-dev/**
# Cloudflare Pages production build output (regenerated by app/cf-build.sh)
app/web/dist/**

# Disposable agent-docs v2 agent workspaces.
.agent-docs/
# Legacy v2 proof output; kept ignored for cleanup/backcompat.
docs/.generated/

# stray capture dir when harness cwd is app/
app/captures/
app/tools/captures/
